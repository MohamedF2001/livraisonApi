{
  "openapi": "3.0.0",
  "info": {
    "title": "ILLICO DELIVERY API",
    "version": "1.1.0",
    "description": "Plateforme de livraison express & points de collecte — Cotonou & Abomey-Calavi\n\n## 🎯 Fonctionnalités\n- Authentification multi-rôles (Admin, Client, Livreur, Point ILLICO)\n- Gestion des livraisons en temps réel avec code de suivi unique\n- Attribution automatique par zone et véhicule\n- Points de collecte avec stockage temporaire\n- Calcul tarifaire dynamique\n- Paiements & commissions\n- Notifications push\n\n## 🔐 Authentification\nToutes les routes protégées nécessitent un token JWT dans le header :\n```\nAuthorization: Bearer <votre_token_jwt>\n```\n\n## 🌍 Base URL\n- Development: `http://localhost:3000/api`\n- Production: `https://illico-delivery.vercel.app/api`"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development (Local)"
    },
    {
      "url": "https://illico-delivery.vercel.app/api",
      "description": "Production (Vercel)"
    }
  ],
  "tags": [
    { "name": "🔐 Auth", "description": "Authentification & gestion de profil multi-rôles" },
    { "name": "📦 Livraisons", "description": "Création, suivi et gestion des livraisons" },
    { "name": "🚴 Livreurs", "description": "Gestion des livreurs, missions et positions" },
    { "name": "🚗 Véhicules", "description": "Types de véhicules et paramètres tarifaires" },
    { "name": "🗺️ Zones", "description": "Zones géographiques de livraison" },
    { "name": "🏪 Points ILLICO", "description": "Points de collecte et gestion des colis" },
    { "name": "📦 Colis", "description": "Gestion des colis en point de collecte" },
    { "name": "💰 Tarifs", "description": "Grilles tarifaires et estimation de prix" },
    { "name": "💳 Transactions", "description": "Historique des paiements et commissions" },
    { "name": "🎫 Forfaits", "description": "Abonnements clients professionnels" },
    { "name": "🔔 Notifications", "description": "Alertes et messages utilisateurs" },
    { "name": "👨‍💼 Admin", "description": "Endpoints réservés aux administrateurs" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenu après connexion. Format: `Bearer <token>`"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "description": "Utilisateur (4 rôles possibles: Admin, Client, Livreur, PointIllico)",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9d0" },
          "nom": { "type": "string", "example": "Koffi Mensah" },
          "telephone": { "type": "string", "example": "+22997123456" },
          "email": { "type": "string", "example": "admin@illicodelivery.bj", "nullable": true },
          "role": { "type": "string", "enum": ["Admin", "Client", "Livreur", "PointIllico"], "example": "Client" },
          "adresse": { "type": "string", "example": "Cotonou, Haie Vive, Rue 123", "nullable": true },
          "typeClient": { "type": "string", "enum": ["standard", "professionnel"], "example": "professionnel", "nullable": true },
          "soldeIllico": { "type": "number", "example": 15000, "nullable": true },
          "forfaitActif": { "type": "string", "nullable": true, "example": "65f2a1b2c3d4e5f6a7b8c9d1" },
          "vehicule": { "type": "object", "nullable": true, "example": { "_id": "65f2a1b2c3d4e5f6a7b8c9d2", "type": "moto", "tarifBase": 500 } },
          "zonesDintervention": { "type": "array", "items": { "type": "string" }, "example": ["65f2a1b2c3d4e5f6a7b8c9c0"] },
          "statut": { "type": "string", "enum": ["en_ligne", "hors_ligne", "en_mission"], "example": "en_ligne", "nullable": true },
          "scoreNote": { "type": "number", "minimum": 0, "maximum": 5, "example": 4.8, "nullable": true },
          "cashCollecte": { "type": "number", "example": 25000, "nullable": true },
          "cashReverse": { "type": "number", "example": 10000, "nullable": true },
          "valide": { "type": "boolean", "example": true, "nullable": true },
          "actif": { "type": "boolean", "example": true, "nullable": true },
          "commissionTotal": { "type": "number", "example": 5000, "nullable": true },
          "location": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "example": "Point" },
              "coordinates": { "type": "array", "items": { "type": "number" }, "example": [2.4394, 6.3654] }
            }
          }
        }
      },
      "Livraison": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9e0" },
          "client": { "$ref": "#/components/schemas/User" },
          "livreur": { "$ref": "#/components/schemas/User", "nullable": true },
          "codeSuivi": { "type": "string", "example": "A1B2C" },
          "pointDepart": {
            "type": "object",
            "properties": {
              "nomExpediteur": { "type": "string", "example": "M. Dupont" },
              "adresse": { "type": "string", "example": "Cotonou, Haie Vive" },
              "telephoneContact": { "type": "string", "example": "+22997000000" },
              "coordinates": { "type": "array", "items": { "type": "number" }, "example": [2.4394, 6.3654] }
            }
          },
          "pointArrivee": {
            "type": "object",
            "properties": {
              "nomDestinataire": { "type": "string", "example": "Mme. Doe" },
              "adresse": { "type": "string", "example": "Abomey-Calavi, Godomey" },
              "telephoneContact": { "type": "string", "example": "+22997000001" },
              "coordinates": { "type": "array", "items": { "type": "number" }, "example": [2.3558, 6.4478] }
            }
          },
          "vehicule": { "type": "object", "properties": { "_id": { "type": "string" }, "type": { "type": "string" }, "tarifBase": { "type": "number" } } },
          "mode": { "type": "string", "enum": ["express", "point_illico"], "example": "express" },
          "pointIllico": { "$ref": "#/components/schemas/User", "nullable": true },
          "statut": { "type": "string", "enum": ["en_attente", "affecté", "arrivé_pickup", "colis_récupéré", "déposé_en_point", "livré", "échoué", "annulé"], "example": "en_attente" },
          "prixEstime": { "type": "number", "example": 2500 },
          "prixFinal": { "type": "number", "nullable": true, "example": 2500 },
          "modePaiement": { "type": "string", "enum": ["cash", "mobile_money", "credit_illico"], "example": "cash" },
          "preuveLivraisonUrl": { "type": "string", "example": "https://res.cloudinary.com/.../proof.jpg", "nullable": true },
          "noteLivreur": { "type": "number", "minimum": 1, "maximum": 5, "nullable": true },
          "natureColis": { "type": "string", "example": "Documents importants" },
          "urgent": { "type": "boolean", "example": false },
          "nuit": { "type": "boolean", "example": false },
          "poids": { "type": "number", "example": 2.5 },
          "dateCreation": { "type": "string", "format": "date-time", "example": "2026-04-15T10:30:00Z" },
          "dateLivraison": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "Colis": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9f0" },
          "reference": { "type": "string", "example": "COL-K9X2M-4P7Q" },
          "livraison": { "$ref": "#/components/schemas/Livraison" },
          "pointIllico": { "$ref": "#/components/schemas/User" },
          "statut": { "type": "string", "enum": ["en_attente", "receptionné", "retiré", "retourné"], "example": "receptionné" },
          "dateDepot": { "type": "string", "format": "date-time", "example": "2026-04-15T14:00:00Z" },
          "dateLimiteGratuite": { "type": "string", "format": "date-time", "example": "2026-04-17T14:00:00Z" },
          "dateRetrait": { "type": "string", "format": "date-time", "nullable": true },
          "fraisStockage": { "type": "number", "example": 0 },
          "fraisStockageActuel": { "type": "number", "example": 400, "description": "Calculé à la volée si retard" },
          "otpRetrait": { "type": "string", "example": "456789", "writeOnly": true },
          "signatureUrl": { "type": "string", "nullable": true }
        }
      },
      "Tarif": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9a0" },
          "vehicule": { "type": "object", "properties": { "_id": { "type": "string" }, "type": { "type": "string" } } },
          "zone": { "type": "object", "properties": { "_id": { "type": "string" }, "nom": { "type": "string" }, "supplement": { "type": "number" } } },
          "prixBase": { "type": "number", "example": 500 },
          "coutKm": { "type": "number", "example": 150 },
          "supplementUrgent": { "type": "number", "example": 1000 },
          "supplementNuit": { "type": "number", "example": 500 },
          "supplementPoids": { "type": "number", "example": 100 },
          "remisePointIllico": { "type": "number", "example": 10, "description": "Pourcentage de remise" },
          "actif": { "type": "boolean", "example": true }
        }
      },
      "Vehicule": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9b0" },
          "type": { "type": "string", "enum": ["velo", "moto", "tricycle", "voiture", "camionnette"], "example": "moto" },
          "tarifBase": { "type": "number", "example": 500 },
          "coutParKm": { "type": "number", "example": 150 },
          "commission": { "type": "number", "example": 20, "description": "Pourcentage de commission livreur" },
          "description": { "type": "string", "example": "Idéal pour livraisons urbaines rapides" },
          "actif": { "type": "boolean", "example": true }
        }
      },
      "Zone": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9c0" },
          "nom": { "type": "string", "example": "Cotonou Centre" },
          "description": { "type": "string", "example": "Zone urbaine dense" },
          "supplement": { "type": "number", "example": 200 },
          "actif": { "type": "boolean", "example": true }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9d5" },
          "livraison": { "$ref": "#/components/schemas/Livraison", "nullable": true },
          "livreur": { "$ref": "#/components/schemas/User", "nullable": true },
          "client": { "$ref": "#/components/schemas/User" },
          "type": { "type": "string", "enum": ["paiement", "commission_livreur", "commission_point", "stockage", "remboursement"], "example": "commission_livreur" },
          "montant": { "type": "number", "example": 500 },
          "modePaiement": { "type": "string", "enum": ["cash", "mobile_money", "credit_illico"], "example": "cash" },
          "statut": { "type": "string", "enum": ["en_attente", "validé", "échoué"], "example": "validé" },
          "dateTransaction": { "type": "string", "format": "date-time", "example": "2026-04-15T15:30:00Z" },
          "description": { "type": "string", "example": "Commission livraison #c9e0" }
        }
      },
      "Forfait": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9e5" },
          "nom": { "type": "string", "example": "Pro Monthly" },
          "description": { "type": "string", "example": "50 livraisons/mois avec 15% de remise" },
          "prix": { "type": "number", "example": 25000 },
          "dureeJours": { "type": "number", "example": 30 },
          "livraisonsIncluses": { "type": "number", "example": 50 },
          "remise": { "type": "number", "example": 15, "description": "Pourcentage de remise sur les livraisons" },
          "actif": { "type": "boolean", "example": true }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9f5" },
          "destinataire": { "$ref": "#/components/schemas/User" },
          "type": { "type": "string", "enum": ["livraison", "alerte", "paiement", "info"], "example": "livraison" },
          "message": { "type": "string", "example": "Votre colis #COL-K9X2M-4P7Q est prêt au retrait" },
          "lu": { "type": "boolean", "example": false },
          "dateCreation": { "type": "string", "format": "date-time", "example": "2026-04-15T16:00:00Z" },
          "lien": { "type": "string", "nullable": true, "example": "/colis/65f2a1b2c3d4e5f6a7b8c9f0" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "Connexion réussie." },
          "data": {
            "type": "object",
            "properties": {
              "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." },
              "user": { "$ref": "#/components/schemas/User" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Identifiants invalides." },
          "errors": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["Email requis", "Mot de passe trop court"],
            "nullable": true
          }
        }
      },
      "PrixEstimation": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "Estimation calculée." },
          "data": {
            "type": "object",
            "properties": {
              "distance": { "type": "string", "example": "4.25" },
              "prixEstime": { "type": "number", "example": 2500 },
              "details": {
                "type": "object",
                "properties": {
                  "tarifBase": { "type": "number", "example": 500 },
                  "coutKm": { "type": "number", "example": 150 },
                  "supplementZone": { "type": "number", "example": 200 },
                  "supplementUrgent": { "type": "number", "example": 0 },
                  "supplementNuit": { "type": "number", "example": 0 },
                  "supplementPoids": { "type": "number", "example": 150 },
                  "remise": { "type": "number", "example": 0 }
                }
              }
            }
          }
        }
      },
      "LivraisonCreateRequest": {
        "type": "object",
        "required": ["pointDepart", "pointArrivee", "vehicule", "mode", "natureColis"],
        "properties": {
          "pointDepart": {
            "type": "object",
            "required": ["adresse", "coordinates", "telephoneContact", "nomExpediteur"],
            "properties": {
              "nomExpediteur": { "type": "string", "example": "M. Dupont" },
              "adresse": { "type": "string", "example": "Cotonou, Haie Vive, Rue 123" },
              "telephoneContact": { "type": "string", "example": "+22997000000" },
              "coordinates": { "type": "array", "items": { "type": "number" }, "example": [2.4394, 6.3654], "description": "[longitude, latitude]" }
            }
          },
          "pointArrivee": {
            "type": "object",
            "required": ["adresse", "coordinates", "telephoneContact", "nomDestinataire"],
            "properties": {
              "nomDestinataire": { "type": "string", "example": "Mme. Doe" },
              "adresse": { "type": "string", "example": "Abomey-Calavi, Godomey, Carrefour" },
              "telephoneContact": { "type": "string", "example": "+22997000001" },
              "coordinates": { "type": "array", "items": { "type": "number" }, "example": [2.3558, 6.4478] }
            }
          },
          "vehicule": { "type": "string", "example": "65f2a1b2c3d4e5f6a7b8c9b0", "description": "ID du véhicule (Vehicule._id)" },
          "mode": { "type": "string", "enum": ["express", "point_illico"], "example": "express" },
          "pointIllico": { "type": "string", "nullable": true, "example": "65f2a1b2c3d4e5f6a7b8c9d3", "description": "ID du point ILLICO (si mode=point_illico)" },
          "natureColis": { "type": "string", "example": "Documents importants" },
          "urgent": { "type": "boolean", "example": false },
          "nuit": { "type": "boolean", "example": false },
          "poids": { "type": "number", "example": 2.5, "description": "Poids du colis en kg" },
          "modePaiement": { "type": "string", "enum": ["cash", "mobile_money", "credit_illico"], "example": "cash" }
        }
      },
      "LivreurPositionRequest": {
        "type": "object",
        "required": ["coordinates"],
        "properties": {
          "coordinates": {
            "type": "array",
            "items": { "type": "number" },
            "example": [2.4394, 6.3654],
            "description": "[longitude, latitude] de la position actuelle du livreur",
            "minItems": 2,
            "maxItems": 2
          }
        }
      },
      "StatutUpdateRequest": {
        "type": "object",
        "required": ["statut"],
        "properties": {
          "statut": {
            "type": "string",
            "enum": ["en_attente", "affecté", "arrivé_pickup", "colis_récupéré", "déposé_en_point", "livré", "échoué", "annulé"],
            "example": "livré"
          }
        }
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "ID MongoDB de la ressource",
        "example": "65f2a1b2c3d4e5f6a7b8c9d0"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Non authentifié",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "success": false, "message": "Token invalide ou expiré." }
          }
        }
      },
      "Forbidden": {
        "description": "Accès refusé (rôle insuffisant)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "success": false, "message": "Accès réservé aux administrateurs." }
          }
        }
      },
      "NotFound": {
        "description": "Ressource non trouvée",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "success": false, "message": "Livraison non trouvée." }
          }
        }
      },
      "BadRequest": {
        "description": "Requête invalide",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "success": false, "message": "Champs requis manquants.", "errors": ["telephone requis"] }
          }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/auth/admin/register": {
      "post": {
        "tags": ["🔐 Auth"],
        "summary": "Inscription administrateur",
        "description": "Crée un nouveau compte administrateur. Réservé à l'initialisation du système.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nom", "email", "motDePasse", "telephone"],
                "properties": {
                  "nom": { "type": "string", "example": "Admin Principal" },
                  "email": { "type": "string", "format": "email", "example": "admin@illicodelivery.bj" },
                  "motDePasse": { "type": "string", "minLength": 6, "example": "Admin123!" },
                  "telephone": { "type": "string", "example": "+22997000001" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin créé avec succès",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/auth/admin/login": {
      "post": {
        "tags": ["🔐 Auth"],
        "summary": "Connexion administrateur",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "motDePasse"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "admin@illicodelivery.bj" },
                  "motDePasse": { "type": "string", "example": "Admin123!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connexion réussie",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" },
                "example": {
                  "success": true,
                  "message": "Connexion réussie.",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "user": {
                      "_id": "65f2a1b2c3d4e5f6a7b8c9d0",
                      "nom": "Admin Principal",
                      "email": "admin@illicodelivery.bj",
                      "telephone": "+22997000001",
                      "role": "Admin"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/client/register": {
      "post": {
        "tags": ["🔐 Auth"],
        "summary": "Inscription client (avec OTP)",
        "description": "Processus en 2 étapes:\n1. `?action=init` → Envoi OTP au téléphone\n2. Sans params → Validation OTP + création compte",
        "security": [],
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "schema": { "type": "string", "enum": ["init"] },
            "description": "init = demander envoi OTP"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "telephone": { "type": "string", "example": "+22997123456" },
                  "codePin": { "type": "string", "pattern": "^[0-9]{4,6}$", "example": "1234", "description": "4-6 chiffres" },
                  "nom": { "type": "string", "example": "Koffi Mensah" },
                  "adresse": { "type": "string", "example": "Cotonou, Haie Vive" },
                  "typeClient": { "type": "string", "enum": ["standard", "professionnel"], "example": "standard" },
                  "otp": { "type": "string", "pattern": "^[0-9]{6}$", "example": "123456", "description": "Requis pour étape 2" }
                }
              }
            }
          }
